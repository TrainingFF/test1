{
  "openapi": "3.0.0",
  "info": {
    "title": "GitHub API - Sample Spec",
    "version": "1.0.0",
    "description": "Subset of GitHub REST API for testing"
  },
  "servers": [
    {
      "url": "https://api.github.com"
    }
  ],
  "paths": {
    "/users/{username}": {
      "get": {
        "summary": "Get user details",
        "parameters": [
          {
            "name": "username",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "octocat"
          }
        ],
        "responses": {
          "200": {
            "description": "User details retrieved"
          },
          "404": {
            "description": "User not found"
          }
        }
      }
    },
    "/user/repos": {
      "get": {
        "summary": "Get authenticated user repositories",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "List of repositories"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/repos/{owner}/{repo}": {
      "get": {
        "summary": "Get repository details",
        "parameters": [
          {
            "name": "owner",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "octocat"
          },
          {
            "name": "repo",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "Hello-World"
          }
        ],
        "responses": {
          "200": {
            "description": "Repository details"
          },
          "404": {
            "description": "Repository not found"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "token"
      }
    }
  }
}